{
  "name": "mockmind",
  "version": "0.1.0",
  "description": "A TypeScript mock server for OpenAI-compatible and LLM provider APIs",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mockmind": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "docs"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsup src/cli/index.ts src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "latest",
    "commander": "latest",
    "fastify": "latest",
    "yaml": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsup": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "author": "MockMind contributors",
  "homepage": "https://github.com/Devliang24/mockmind#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Devliang24/mockmind.git"
  },
  "bugs": {
    "url": "https://github.com/Devliang24/mockmind/issues"
  },
  "keywords": [
    "llm",
    "mock-server",
    "openai",
    "anthropic",
    "gemini",
    "dashscope",
    "fastify",
    "testing",
    "agent",
    "rag",
    "sdk-testing"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  }
}
